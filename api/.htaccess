# Optional pretty URLs for /api/*
# If AllowOverride is enabled, you can call:
#   http://localhost/POI_Admin/api/pois
# Otherwise, call:
#   http://localhost/POI_Admin/api/index.php/pois

RewriteEngine On
RewriteBase /POI_Admin/api/
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]
RewriteRule ^ index.php [QSA,L]
